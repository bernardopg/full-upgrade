# full-upgrade — configuração do usuário
# Copie para ~/.config/full-upgrade/config e edite.
# É um arquivo bash sourced: use sintaxe shell (VAR=valor, arrays, etc).
#
# ─────────────────────────────────────────────────────────────────────────────
# full-upgrade — user configuration
# Copy to ~/.config/full-upgrade/config and edit.
# It is a sourced bash file: use shell syntax (VAR=value, arrays, etc).

# ── Idioma / Language ──────────────────────────────────────────────────────────
# auto = detecta de $LANG | pt = Português | en = English
LANG_OVERRIDE=auto

# ── Tools custom / Custom tools ─────────────────────────────────────────────────
# As integrações empacotadas (Hermes, AdGuard, Copilot, DMS, OpenClaw, RTK) rodam
# POR PRESENÇA da ferramenta — não precisam desta flag. ENABLE_CUSTOM_TOOLS=1 só é
# necessário para: (a) Burp/Wireshark, que INSTALA o pacote burpsuite; (b) carregar
# seus próprios plugins de ~/.config/full-upgrade/steps.d/.
# Packaged integrations run by tool presence; this flag only enables Burp/Wireshark
# (which installs burpsuite) and loading your own ~/.config/full-upgrade/steps.d/.
ENABLE_CUSTOM_TOOLS=0

# ── Snapshot pré-upgrade / Pre-upgrade snapshot ─────────────────────────────────
# auto = usa snapper se existir, senão timeshift; none = desliga
SNAPSHOT_TOOL=auto
SNAPSHOT_MIN_FREE_GIB=2  # mínimo livre em / para criar snapshot; 0 desliga checagem
SNAPSHOT_KEEP=5          # snapshots full-upgrade antigos a manter na limpeza

# ── Backup de configs críticas / Critical config backup ─────────────────────────
# Arquiva configs essenciais de /etc em tar.zst antes das mutações, com rotação.
BACKUP_CONFIGS=1        # 1 = ativo | 0 = desliga
BACKUP_KEEP=5           # quantos tarballs manter (rotação)
# Paths a arquivar (separados por espaço). Default cobre boot/pacman/systemd.
# BACKUP_PATHS="/etc/pacman.conf /etc/pacman.d /etc/fstab /etc/mkinitcpio.conf /etc/systemd/system"

# ── Mirror refresh ──────────────────────────────────────────────────────────────
# auto = detecta reflector/rate-mirrors | reflector | rate-mirrors | none
MIRROR_TOOL=auto

# ── Espaço mínimo livre / Min free space ────────────────────────────────────────
MIN_FREE_GIB=2          # em / (GiB)
MIN_BOOT_FREE_MIB=200   # em /boot (MiB — ESP costuma ser pequeno)

# ── Limiares, timeouts e limites / Thresholds, timeouts and limits ───────────────
BTRFS_SCRUB_MAX_DAYS=30  # alerta se o último scrub btrfs em / for mais antigo
BOOT_TIME_WARN_S=60      # alerta se o boot (systemd-analyze) exceder N segundos
DOCKER_INFO_TIMEOUT_S=5  # timeout para detectar daemon Docker inacessível
ORPHAN_CLEANUP_MAX_ROUNDS=5  # rodadas máximas para remover órfãos recursivos

# ── Listas de ignore / Ignore lists ─────────────────────────────────────────────
# Pacotes AUR a não atualizar automaticamente / AUR packages to skip
# Ex: FULL_UPGRADE_AUR_IGNORE="burpsuite"
FULL_UPGRADE_AUR_IGNORE=""
# Pacotes pip --user a ignorar / pip --user packages to skip.
# Se Poetry fixa uma versão exata de poetry-core, poetry-core é adicionado
# automaticamente ao ignore efetivo para evitar conflito/ping-pong de versão.
FULL_UPGRADE_PIP_USER_IGNORE=""

# ── Overrides de path (vazio = auto-detecta) / Path overrides (empty = auto) ─────
# GCLOUD_BIN="$HOME/google-cloud-sdk/bin/gcloud"
# COPILOT_BIN="$HOME/.local/bin/copilot"
# ADGUARD_BIN="/usr/local/bin/adguardvpn-cli"
# DMS_PLUGINS_DIR="$HOME/.config/DankMaterialShell/plugins"
# OPENCLAW_BIN="/usr/local/bin/openclaw"
# ORCA_IDE_BIN="$HOME/.local/bin/stably-orca"
# RTK_BIN="$HOME/.local/bin/rtk"
# BURPSUITE_JAVA_BIN="/usr/lib/jvm/java-21-openjdk/bin/java"  # Java p/ o fallback do Burp

# ── Auto-atualização do próprio full-upgrade / Self-update ──────────────────────
# Repositório de origem (owner/repo no GitHub) e canal de atualização.
# release = última tag publicada (estável) | main = topo da branch (bleeding edge)
# Usados por 'full-upgrade --update' e pelo aviso passivo de nova versão.
FULL_UPGRADE_REPO="bernardopg/full-upgrade"
FULL_UPGRADE_UPDATE_CHANNEL="release"

# ── Systray daemon (ícone de bandeja) / Systray daemon ──────────────────────────
# Wayland/Hyprland: usa AppIndicator via python-gobject + libayatana-appindicator.
# X11: usa yad --notification. Inicie com 'full-upgrade --tray'.
# TRAY_CHECK_INTERVAL_M  intervalo de checagem em minutos (mín. 1; default 30)
# TRAY_TERMINAL          terminal emulator (vazio = auto-detecta; ex.: kitty)
# TRAY_NOTIFICATIONS     1 = notifica no desktop em transições de estado | 0 = off
TRAY_CHECK_INTERVAL_M=30
TRAY_TERMINAL=""
TRAY_NOTIFICATIONS=1
